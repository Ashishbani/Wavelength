# --- Server configuration ---

# Port to listen on (a host may set this automatically).
PORT=3001

# REQUIRED: a strong, unique secret for signing login tokens.
# The server refuses to start without it. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Set to 'true' when the app is served over HTTPS (deploy / tunnel / domain),
# so the auth cookie gets the Secure flag. Leave unset for local http dev.
COOKIE_SECURE=

# Optional: restrict CORS to a specific client origin. If unset, the server
# reflects the request origin (fine for single-origin deploys and tunnels).
# CLIENT_ORIGIN=https://your-domain.example

# SQLite database file. Use an ABSOLUTE path on a persistent volume in prod
# (otherwise data is recreated empty on every restart).
DB_PATH=wavelength.sqlite
